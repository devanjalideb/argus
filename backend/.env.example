# ========================= ARGUS backend configuration =========================
# Copy to `.env` and fill in secrets. Never commit `.env`.

# ---- Application ----
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ---- Database (MySQL) ----
# Either set the individual parts below, or a full DATABASE_URL that overrides them.
# DATABASE_URL=mysql+pymysql://user:pass@localhost:3306/argus?charset=utf8mb4
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DB=argus

# ---- Security (JWT) ----
SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ---- AI Decision Layer (OpenRouter) ----
# Optional. When empty, ARGUS uses a fully offline, grounded fallback narrator,
# so the platform works with no internet and no API key.
AI_ENABLED=true
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# ---- Synthetic data ----
SYNTHETIC_SEED=42
